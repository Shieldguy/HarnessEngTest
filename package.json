{
  "name": "powerball-predictor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "scrape": "bun src/scraper/index.ts",
    "analyze": "bun src/analyzer/index.ts",
    "dev": "bun src/server/index.ts",
    "build": "bun run build:client && bun run build:server",
    "build:client": "cd src/client && bun run build",
    "build:server": "bun build src/server/index.ts --outfile dist/server.js --target bun",
    "start": "bun dist/server.js",
    "test": "bun test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "@vitejs/plugin-react": "^4.3.2"
  }
}
